# ---- Secrets (NEVER commit) ----
backend/.env
backend/.env.*
backend/serviceAccount*.json
**/serviceAccount*.json
*-firebase-adminsdk-*.json
RENDER_ENV_VALUES.txt

# ---- Android release signing (NEVER commit — losing these = can't update app) ----
**/*.jks
**/*.keystore
**/key.properties

# ---- Node ----
**/node_modules/
*.log

# ---- Flutter/Dart (app/ also has its own .gitignore) ----
app/.dart_tool/
app/build/
app/.flutter-plugins
app/.flutter-plugins-dependencies
**/*.iml

# ---- OS ----
.DS_Store
Thumbs.db
